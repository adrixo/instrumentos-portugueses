# Copia a .env y ajusta. (ADR §25)
EXPERIMENT_OFFLINE=false                 # true bloquea HTTP externo salvo endpoints locales (ADR §15.3)
SEED=42
MLFLOW_TRACKING_URI=sqlite:///outputs/mlflow.db
VLM_BASE_URL=http://localhost:8001/v1    # servidor vLLM OpenAI-compatible (B4/B5)
VLM_MODEL=qwen2.5-vl
VLM_MODEL_HF=Qwen/Qwen2.5-VL-7B-Instruct # modelo servido por docker/vLLM
VLLM_IMAGE=vllm/vllm-openai:v0.10.1.1
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.80
VLM_MAX_IMAGE_SIDE=768
VLM_JPEG_QUALITY=85
VLM_WORKERS=1
VLM_CACHE=1
VLM_CACHE_DIR=outputs/cache/vlm_openai
HF_HOME=./models/huggingface
