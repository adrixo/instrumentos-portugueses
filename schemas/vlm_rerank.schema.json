{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://instrument-ir/schemas/vlm_rerank.schema.json",
  "title": "B4 VLM pointwise rerank output",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "confidence", "visual_evidence", "negative_evidence", "score"],
  "properties": {
    "decision": { "type": "string", "enum": ["present", "absent", "uncertain"] },
    "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "visual_evidence": { "type": "array", "maxItems": 4, "items": { "type": "string", "maxLength": 120 } },
    "negative_evidence": { "type": "array", "maxItems": 4, "items": { "type": "string", "maxLength": 120 } },
    "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
  }
}
